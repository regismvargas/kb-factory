# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Test artifacts
.pytest_cache/
.pytest_tmp_*/
test-tmp-*/

# KB runtime byproducts — the SQLite database is generated by `kb.py init`
# and must never be committed (it is per-project data, not source).
# The public product ships NO `.kb/` at the repo root: a project's `.kb/` is
# created by `kb.py init` in the consumer's own project, not here.
/.kb/
*.db
*.db-shm
*.db-wal
.kb/wiki/snapshots/

# Secrets / local env
.env
.env.*
*.pem
*.key

# Build output
dist/
build/

# Agent / editor session data (user-local)
.claude/
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Temp
.tmp/

# Internal design spec & its validators — kept in the private workbench, NOT
# published. The vNext runtime ships; its internal design "ceremony" docs do not.
# (Excluded at publication; files remain in the staging tree but are never
# committed to the public repo.)
core/versions/kb-wiki-vnext/spec-pack/
core/versions/kb-wiki-vnext/README.md
core/versions/kb-wiki-vnext/runtime/README.md
tests/test_kb_wiki_vnext_spec_pack.py
tools/validate_kb_wiki_vnext_spec_pack.py
