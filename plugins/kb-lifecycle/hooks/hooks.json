{
  "description": "Inject a short KB Factory session reminder when a workspace contains a .kb directory.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}\"/scripts/session_start_context.py"
          }
        ]
      }
    ]
  }
}
